.app-shell {
  min-height: 100vh;
  background: linear-gradient(180deg, #d5bea3 0%, #ded4c6 100%);
  overflow-x: hidden;
}

.view {
  width: 100%;
  max-width: 720px;
  min-height: 100vh;
  margin: 0 auto;
  padding: calc(env(safe-area-inset-top) + 32rpx) 28rpx calc(env(safe-area-inset-bottom) + 184rpx);
  box-sizing: border-box;
}

.topbar {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.topbar.compact {
  justify-content: flex-start;
}

.page-title,
.hero-title,
.test-word,
.study-word,
.detail-word {
  display: block;
  color: #221f1c;
  font-weight: 900;
  line-height: 1.18;
}

.page-title {
  font-size: 44rpx;
}

.eyebrow,
.section-label,
.muted,
.hint,
.option-sub {
  display: block;
  color: #776d64;
}

.eyebrow,
.section-label {
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.hero-panel,
.question-panel,
.result-panel,
.study-card,
.audio-panel,
.report-panel,
.empty-state,
.detail-card {
  background: rgba(255, 255, 255, 0.46);
  border: 2rpx solid rgba(54, 45, 39, 0.14);
  border-radius: 16rpx;
  padding: 36rpx;
  box-shadow: 0 28rpx 68rpx rgba(62, 48, 38, 0.16);
  box-sizing: border-box;
}

.hero-title {
  max-width: 100%;
  margin-bottom: 36rpx;
  font-size: 48rpx;
  word-break: break-word;
}

.primary-button,
.secondary-button,
.list-button,
.option-card,
.icon-button,
.text-link,
.segmented button,
.sound-button,
.speaker-tile,
.sound-mini,
.select-toggle,
.word-link {
  border: 0;
  line-height: 1.2;
  margin: 0;
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  min-height: 96rpx;
  border-radius: 16rpx;
  padding: 0 36rpx;
  font-weight: 900;
}

.primary-button {
  background: #0d8f7a;
  color: #fff;
}

.primary-button[disabled] {
  opacity: 0.45;
}

.primary-button.small {
  min-height: 84rpx;
}

.hero-panel .primary-button,
.result-panel .primary-button,
.report-panel .primary-button,
.empty-state .primary-button {
  min-width: 300rpx;
  margin: 0 auto;
}

.secondary-button {
  background: rgba(255, 255, 255, 0.72);
  color: #07705f;
}

.icon-button {
  display: flex;
  flex: 0 0 84rpx;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  min-width: 84rpx;
  max-width: 84rpx;
  height: 84rpx;
  padding: 0;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.54);
  color: #221f1c;
  font-size: 48rpx;
  text-align: center;
}

.topbar.compact .icon-button {
  flex: 0 0 84rpx;
  width: 84rpx;
  min-width: 84rpx;
  max-width: 84rpx;
}

.coach-strip,
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin: 28rpx 0;
}

.stats-grid {
  grid-template-columns: repeat(3, 1fr);
}

.coach-strip view,
.metric,
.info-strip view,
.copy-card,
.review-summary {
  border: 2rpx solid rgba(54, 45, 39, 0.14);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.56);
  padding: 24rpx;
  box-sizing: border-box;
}

.coach-strip text:first-child,
.strong,
.card-title {
  display: block;
  font-weight: 900;
}

.info-strip,
.action-list,
.option-stack,
.word-list,
.review-stack {
  display: grid;
  width: 100%;
  gap: 24rpx;
  margin: 28rpx 0;
}

.metric {
  text-align: center;
}

.metric text:first-child {
  display: block;
  font-size: 42rpx;
  font-weight: 900;
}

.metric text:last-child {
  display: block;
  color: #776d64;
  font-size: 24rpx;
}

.list-button {
  width: 100%;
  min-width: 0;
  justify-self: stretch;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  min-height: 148rpx;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #f6f2ec;
  text-align: left;
}

.list-button text:first-child {
  display: block;
  font-weight: 900;
}

.list-button text:last-child {
  display: block;
  color: #776d64;
  font-size: 24rpx;
  text-align: right;
  word-break: break-word;
}

.progress-label {
  margin-left: auto;
  color: #776d64;
  font-weight: 900;
}

.test-word,
.study-word,
.detail-word {
  margin: 24rpx 0;
  font-size: 64rpx;
  overflow-wrap: anywhere;
  word-break: break-word;
}

.option-card {
  width: 100%;
  min-height: 108rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff;
  color: #221f1c;
  text-align: left;
  font-weight: 800;
  white-space: normal;
  word-break: break-word;
}

.option-card.correct {
  background: #d9f2e9;
  color: #07705f;
}

.option-card.wrong {
  background: #f6d4d2;
  color: #a94240;
}

.option-card.muted-card {
  opacity: 0.45;
}

.unknown-button {
  width: 100%;
  margin-top: 24rpx;
}

.counter-bar,
.bottom-actions {
  position: fixed;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  width: calc(100vw - 56rpx);
  max-width: 720px;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: rgba(246, 242, 236, 0.94);
  box-shadow: 0 20rpx 48rpx rgba(62, 48, 38, 0.16);
  box-sizing: border-box;
}

.bottom-actions.two {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  align-items: stretch;
}

.bottom-actions .primary-button,
.bottom-actions .secondary-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  padding: 0 20rpx;
  overflow: hidden;
}

.pill {
  min-width: 72rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #fff;
  text-align: center;
  font-weight: 900;
}

.green {
  background: #0d8f7a;
}

.red {
  background: #cf5f5d;
}

.blue {
  background: #4f87c7;
}

.vocab-number {
  display: block;
  margin: 24rpx 0;
  font-size: 96rpx;
  font-weight: 900;
  color: #0d8f7a;
}

.precheck-row,
.review-card {
  display: grid;
  grid-template-columns: 40rpx 68rpx minmax(0, 1fr);
  align-items: center;
  gap: 18rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(54, 45, 39, 0.14);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.62);
  box-sizing: border-box;
}

.precheck-row.picked {
  border-color: #0d8f7a;
}

.index {
  color: #776d64;
  font-weight: 900;
}

.select-toggle,
.sound-mini {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #0d8f7a;
}

.select-toggle.on {
  background: #0d8f7a;
  color: #fff;
}

.word-link {
  padding: 0;
  background: transparent;
  text-align: left;
  font-size: 36rpx;
  font-weight: 900;
  overflow-wrap: anywhere;
}

.meaning-inline {
  grid-column: 3;
  color: #776d64;
  word-break: break-word;
}

.segmented {
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.segmented button {
  width: 100%;
  min-height: 72rpx;
  border-radius: 14rpx;
  background: #f6f2ec;
  color: #776d64;
}

.segmented .selected {
  background: #d9f2e9;
  color: #07705f;
}

.segmented .danger {
  background: #f6d4d2;
  color: #a94240;
}

.completion-burst {
  margin-bottom: 24rpx;
  padding: 22rpx 28rpx;
  border-radius: 16rpx;
  background: #0d8f7a;
  color: #fff;
  font-weight: 900;
}

.memory-image {
  display: grid;
  gap: 10rpx;
  margin: 24rpx 0;
  padding: 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(13, 143, 122, 0.16), rgba(229, 140, 67, 0.2));
}

.memory-mark {
  color: #07705f;
  font-weight: 900;
}

.sound-button,
.speaker-tile {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  margin: 16rpx 0;
  border-radius: 999rpx;
  background: #221f1c;
  color: #fff;
  font-weight: 900;
}

.speaker-tile {
  width: 200rpx;
  height: 200rpx;
  border-radius: 56rpx;
  font-size: 36rpx;
}

.ipa {
  display: block;
  margin: 10rpx 0;
  color: #776d64;
}

.meaning {
  display: block;
  margin: 16rpx 0;
  font-size: 34rpx;
  font-weight: 900;
  word-break: break-word;
}

.meaning text {
  margin-right: 12rpx;
  color: #0d8f7a;
}

.text-link {
  display: inline-block;
  padding: 0;
  background: transparent;
  color: #07705f;
  text-align: left;
  font-weight: 900;
}

.centered {
  display: block;
  margin: 24rpx auto 0;
}

.review-card {
  grid-template-columns: 96rpx 1fr;
}

.review-card text {
  display: block;
}

.review-summary {
  display: grid;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.report-ring {
  display: flex;
  width: 220rpx;
  height: 220rpx;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #0d8f7a;
  color: #fff;
  font-size: 56rpx;
  font-weight: 900;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  padding: calc(env(safe-area-inset-top) + 64rpx) 28rpx calc(env(safe-area-inset-bottom) + 28rpx);
  background: rgba(34, 31, 28, 0.42);
  box-sizing: border-box;
}

.detail-card {
  position: relative;
  width: 100%;
  max-width: 680px;
  max-height: 84vh;
  margin: 0 auto;
  overflow: auto;
  background: #f6f2ec;
}

.close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}

.empty-state {
  display: grid;
  gap: 24rpx;
  text-align: center;
}

@media (max-width: 360px) {
  .view {
    padding-left: 22rpx;
    padding-right: 22rpx;
  }

  .hero-panel,
  .question-panel,
  .result-panel,
  .study-card,
  .audio-panel,
  .report-panel,
  .empty-state,
  .detail-card {
    padding: 28rpx;
  }

  .hero-title {
    font-size: 42rpx;
  }

  .page-title {
    font-size: 40rpx;
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .list-button,
  .bottom-actions {
    align-items: stretch;
    flex-direction: column;
  }

  .bottom-actions .primary-button,
  .bottom-actions .secondary-button {
    width: 100%;
  }

  .test-word,
  .study-word,
  .detail-word {
    font-size: 56rpx;
  }
}

@media (min-width: 520px) {
  .view {
    padding-left: 40rpx;
    padding-right: 40rpx;
  }

  .hero-title {
    font-size: 56rpx;
  }

  .page-title {
    font-size: 48rpx;
  }

  .hero-panel,
  .question-panel,
  .result-panel,
  .study-card,
  .audio-panel,
  .report-panel,
  .empty-state,
  .detail-card {
    padding: 44rpx;
  }

  .coach-strip {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .info-strip {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
